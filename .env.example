# Supabase
NEXT_PUBLIC_SUPABASE_URL=project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=anon-key
SUPABASE_SERVICE_ROLE_KEY=service-role-key

# Ollama (Local LLM inference)
# Required: Ollama must be running locally on localhost:11434
# Download: https://ollama.ai
# Usage: ollama pull llama3.1:8b && ollama serve
OLLAMA_API_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# AI provider keys (set in production)
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
HUGGINGFACE_API_KEY=

# Feature flags
# Set to "1" or "true" to enable LLM-first generation
AI_USE_LLM=1

# Provider order (comma-separated). Options: anthropic, openrouter, huggingface
# Example: anthropic,openrouter,huggingface
AI_PROVIDER_ORDER=anthropic,openrouter,huggingface

# Per-provider ordered model fallbacks. Environment variable names are
# `AI_PROVIDER_MODELS_<PROVIDER>` where <PROVIDER> is uppercased.
# Example: AI_PROVIDER_MODELS_ANTHROPIC=claude-opus-4-7,claude-2
# Example: AI_PROVIDER_MODELS_OPENROUTER=gpt-4o-mini,gpt-4o
AI_PROVIDER_MODELS_ANTHROPIC=
AI_PROVIDER_MODELS_OPENROUTER=
AI_PROVIDER_MODELS_HUGGINGFACE=

# Cache TTL for LLM responses (milliseconds)
AI_CACHE_TTL_MS=300000

# Per-provider timeout (ms) and retry count used by router (optional overrides)
PROVIDER_TIMEOUT_MS=8000
PROVIDER_RETRY=1